--- !u!114 &1723206559
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1723206557}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 32c64892b8a305649a458a5d9271b9ab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::UITutorial
  _steps:
  - _text: Welcome to the clockwork circus, Presto! We need your help!
    TutorialImage: {fileID: 0}
    _shouldChangeImage: 0
  - _text: Something wicked has taken hold here...
    TutorialImage: {fileID: 0}
    _shouldChangeImage: 0
  - _text: And my fellow performers have gone haywire!
    TutorialImage: {fileID: 3983635355746028461, guid: 1bc7515d410c2af4d9f846a57096acba, type: 3}
    _shouldChangeImage: 1
  - _text: But I trust you'll find a way to handle them...
    TutorialImage: {fileID: 0}
    _shouldChangeImage: 0
  - _text: WASD to move, SPACE to jump and double jump, SHIFT to dash...
    TutorialImage: {fileID: 2428491428290126477, guid: 09c5619d597d2d24f83c28ca9cf016c3, type: 3}
    _shouldChangeImage: 1
  - _text: And activate your Magic Wand by pressing F.
    TutorialImage: {fileID: 21300000, guid: 2fc66356a520cf646a76ef2746df4dec, type: 3}
    _shouldChangeImage: 1
  - _text: Due to the chaos here, every time you use it, it'll spin to a random option.
    TutorialImage: {fileID: 21300000, guid: 2fc66356a520cf646a76ef2746df4dec, type: 3}
    _shouldChangeImage: 0
  - _text: But watch out for the Wheel of Fortune!
    TutorialImage: {fileID: 21300000, guid: 53d2d9eab41ae504595ae2e94e87c5c9, type: 3}
    _shouldChangeImage: 1
  - _text: You never know what's coming to get you.
    TutorialImage: {fileID: 0}
    _shouldChangeImage: 0
  - _text: And don't forget to get in the other hat!
    TutorialImage: {fileID: 21300000, guid: 0a7b58c881daf00439099757d3373906, type: 3}
    _shouldChangeImage: 1
  - _text: 'Note: Gamepad controls are also supported (work in progress)'
    TutorialImage: {fileID: 0}
    _shouldChangeImage: 0
  _dialogueText: {fileID: 2115129783}
  _jesterAnimator: {fileID: 1177261634}
  _characterCooldown: 0.01
  _imageContainer: {fileID: 661844154}
  _backButton: {fileID: 1862237112}
  _nextButton: {fileID: 1269337304}
